<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link href="/stylesheets/style.css">
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body>
    <div class="main  w-full  min-h-screen bg-zinc-800 ">
        <div class="px-10 text-white py-10 ">
            <form action="/edit" method="post">
                <input class="rounded-lg block border-2  m-5 w-72 bg-grey-400  p-4  disabled  " placeholder="previous name" value="<%= filename %>" type="text"  name="previous">
                <input class="rounded-lg block border-2  m-5 w-72 bg-grey-400  p-4   " type="text" placeholder="new name"  name="new">
                <input class="rounded-lg block   border-2  m-5 w-72 h-12 bg-blue-400  text-black  text-xl border-none "  type="submit" value="update task">
            </form>
        </div>
          
        
        
        
        
    </div>
    
</body>
</html>